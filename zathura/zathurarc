set default-bg "#ffff99"
set statusbar-bg "#cccccc"
set statusbar-fg "#FFFFFF"
set completion-bg "#ffff99"
set completion-fg "#DDDDDD"
set recolor true
set recolor-lightcolor "#ffff99"
